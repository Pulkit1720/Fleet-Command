{
  "expo": {
    "name": "Fleet Coordinate",
    "slug": "fleet-command-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#081a32"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fleetcommand.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fleet Coordinate needs your location to verify you are on-site for jobs.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Fleet Coordinate needs your location to verify you are on-site for jobs."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#081a32"
      },
      "package": "com.fleetcommand.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Fleet Coordinate to use your location for job verification."
        }
      ],
      "expo-font"
    ],
    "scheme": "fleetcommand",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5c1b5e9-cd06-48c5-8763-911dde1707f8"
      }
    }
  }
}
