PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
